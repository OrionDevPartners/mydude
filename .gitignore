# Python-generated files
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info/
*.egg
*.whl

# Virtual environments
.venv/
venv/
env/

# Environment — env_2 secrets never live in git
.env
.env.*
*.env
!.env.example

# Cloud credential drops — service-principal / secret files must never be committed
*azure-owner-sp*
*service-principal*.json
*-sp-*.json
*credentials*.json

# Database
*.db
*.sqlite3

# Runtime memory stores (generated at runtime; not source)
.cognee_data/
.mem0_data/
# Experimental embedded memory stack (DuckDB/SQLite files are runtime artifacts)
data/agent_memory/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
agentledger/experimental/vendor/
.devguard/

# SQLite transient runtime state (Agent Ledger)
agentledger/*.db-journal
agentledger/*.db-wal
agentledger/*.db-shm
