modules = ["python-3.11", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["cargo", "gitFull", "libiconv", "libxcrypt", "libyaml", "openssl", "pkg-config", "playwright-driver", "postgresql", "rustc", "unzip"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Vite Dev"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "security"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "tests"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Vite Dev"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "security"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/test_security_hardening.py"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/run_all.py"

[workflows.workflow.metadata]
isValidation = true

[deployment]
deploymentTarget = "autoscale"
run = ["python", "main.py"]
build = ["bash", "scripts/build-frontend.sh"]

[userenv]

[userenv.shared]
LLM_PROVIDER = "multi"

[userenv.development]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[objectStorage]
defaultBucketID = "replit-objstore-f8ac857a-23d2-46d0-9926-abdf00be51cc"
