modules = ["python-3.11", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["unzip"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"Bot is deployed in production. Run 'python main.py' here only for local testing (will conflict with deployment).\""

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "gce"
run = ["python", "main.py"]
ignorePorts = true

[userenv]

[userenv.shared]
LLM_PROVIDER = "multi"
