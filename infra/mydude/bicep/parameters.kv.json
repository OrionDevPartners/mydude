{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "eastus2"
    },
    "environment": {
      "value": "prod"
    },
    "pgAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/{SUBSCRIPTION_ID}/resourceGroups/MyDude/providers/Microsoft.KeyVault/vaults/mydude-kv"
        },
        "secretName": "pg-admin-password"
      }
    },
    "tenantId": {
      "value": "{TENANT_ID}"
    }
  }
}
